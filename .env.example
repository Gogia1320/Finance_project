# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/finance-db
MONGODB_URI_PRODUCTION=mongodb+srv://username:password@cluster.mongodb.net/finance-db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Logging
LOG_LEVEL=debug
